{
  "name": "@uikode/tide-motion",
  "version": "0.1.0",
  "description": "Animation primitives and SolidJS directives using Web Animations API. Zero runtime deps.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "dev": "vitest"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "solid-js": "^1.9.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "keywords": [
    "animation",
    "web-animations-api",
    "solidjs",
    "directives",
    "motion",
    "tide"
  ],
  "author": "Andy Vandaric <andy@uikode.com>",
  "license": "MIT",
  "homepage": "https://uikode.com/tide-motion",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uikode/tide.git",
    "directory": "packages/tide-motion"
  }
}
